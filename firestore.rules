rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to get current user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Function to check if user is approved admin
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role != 'user' && getUserData().approved == true;
    }

    // specific top level admins
    function isTopAdmin() {
      return isAdmin() && getUserData().role in ['CEO', 'SECRETARY', 'PRESIDENT'];
    }

    // Users Collection
    match /users/{userId} {
      // Anyone can create a user document (sign up)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can read/update their own profile. Admins can read all users and update them (roles/approvals).
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == userId || isTopAdmin());
      allow delete: if isTopAdmin();
    }

    // Content: Films, Series
    match /films/{filmId} {
      // Public can read published. Admins can read/write all.
      allow read: if (resource.data.published == true) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /series/{seriesId} {
      allow read: if (resource.data.published == true) || isAdmin();
      allow write: if isAdmin();
    }

    // Transactions (Payments made by users to access content)
    match /transactions/{transactionId} {
      // User can create their own transaction. User can read their own.
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Only certain admins (Financial Manager, Assistant, Top Admins) can update it. For now allow any admin.
      allow update, delete: if isAdmin();
    }

    // Contributions, Projects, Announcements
    match /contributions/{contribId} {
      allow read, write: if isAdmin();
    }
    match /projects/{projectId} {
      allow read, write: if isAdmin();
    }
    match /announcements/{annId} {
      allow read: if isAdmin();
      allow write: if isTopAdmin() || getUserData().role == 'MANAGING DIRECTOR';
    }

    // Site Settings (Services, Branding, Footer)
    match /site_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
